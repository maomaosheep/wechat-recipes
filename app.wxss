page {
  width: 100%;
  min-height: 100vh;
  overflow-x: hidden;
  color: #37251f;
  background: #fff7f2;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  letter-spacing: 0;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

.page-shell {
  width: 100%;
  max-width: 100vw;
  min-height: 100vh;
  padding: 32rpx 28rpx 64rpx;
  background:
    radial-gradient(circle at 12% 6%, rgba(255, 209, 188, 0.55), transparent 34%),
    linear-gradient(180deg, #fff6f0 0%, #fffaf6 46%, #f8fbf2 100%);
}

.soft-card {
  border: 1rpx solid rgba(117, 73, 54, 0.08);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 18rpx 50rpx rgba(177, 102, 75, 0.12);
}

.primary-btn {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #f37c6b 0%, #e9567c 100%);
  box-shadow: 0 16rpx 34rpx rgba(225, 83, 104, 0.24);
}

.ghost-btn {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(123, 82, 61, 0.16);
  border-radius: 8rpx;
  color: #6e4639;
  font-size: 26rpx;
  background: rgba(255, 255, 255, 0.72);
}

@keyframes floatIn {
  from {
    opacity: 0;
    transform: translateY(22rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes tinyBeat {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.08);
  }
}
