page {
  width: 100%;
  overflow-x: hidden;
}

.home-root {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow-x: hidden;
}

.home-page {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 100vw;
  padding: 32rpx 24rpx 96rpx;
  overflow-x: hidden;
}

.topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 8rpx 2rpx 24rpx;
  animation: floatIn 420ms ease both;
}

.title-block {
  flex: 1;
  min-width: 0;
}

.eyebrow {
  display: block;
  color: #d15d69;
  font-size: 22rpx;
  font-weight: 700;
}

.title {
  display: block;
  margin-top: 8rpx;
  color: #38251f;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
}

.team-line {
  display: block;
  max-width: 420rpx;
  margin-top: 10rpx;
  overflow: hidden;
  color: #8a665c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-entry {
  width: 92rpx;
  height: 58rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  color: #d95b6b;
  font-size: 24rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.86);
}

.top-actions {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
  max-width: 208rpx;
}

.friend-entry {
  width: 92rpx;
  height: 58rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f37c6b, #e9567c);
}

.banner-swiper,
.banner-skeleton {
  width: 100%;
  height: 372rpx;
  border-radius: 8rpx;
  overflow: hidden;
  animation: floatIn 460ms ease both;
}

.banner-card {
  position: relative;
  width: 100%;
  height: 372rpx;
  overflow: hidden;
  border-radius: 8rpx;
  background: #f3dfd4;
}

.banner-card:active {
  transform: scale(0.992);
}

.banner-image {
  width: 100%;
  height: 372rpx;
  display: block;
}

.banner-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 64%;
  background: linear-gradient(180deg, transparent, rgba(45, 29, 22, 0.72));
}

.banner-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 38rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  color: #fff;
}

.banner-kicker {
  align-self: flex-start;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.22);
}

.banner-title {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.22;
  word-break: break-all;
}

.tool-panel {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 16rpx;
  overflow: hidden;
}

.search-field {
  height: 78rpx;
  display: grid;
  grid-template-columns: 44rpx minmax(0, 1fr) 54rpx;
  align-items: center;
  gap: 6rpx;
  padding: 0 10rpx 0 16rpx;
  border: 1rpx solid rgba(123, 82, 61, 0.12);
  border-radius: 8rpx;
  background: #fffaf7;
}

.search-icon {
  color: #d95b6b;
  font-size: 36rpx;
  line-height: 1;
  text-align: center;
}

.search-input {
  width: 100%;
  min-width: 0;
  height: 76rpx;
  color: #3b2923;
  font-size: 26rpx;
}

.search-placeholder {
  color: #a98b80;
  font-size: 25rpx;
}

.clear-search {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #d95b6b;
  font-size: 30rpx;
  background: #fff0f2;
}

.clear-search.hidden {
  opacity: 0;
  pointer-events: none;
}

.tool-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  overflow: hidden;
  border: 1rpx solid rgba(123, 82, 61, 0.14);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.82);
}

.search-btn,
.add-mini-btn {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  border-radius: 0;
  font-size: 25rpx;
  font-weight: 800;
}

.search-btn {
  color: #fff;
  background: linear-gradient(135deg, #ed725f, #e85b80);
  box-shadow: none;
}

.add-mini-btn {
  color: #6e4639;
  border-left: 1rpx solid rgba(123, 82, 61, 0.14);
  background: transparent;
}

.manage-btn {
  width: 100%;
}

.wheel-entry {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  color: #d95b6b;
  font-size: 26rpx;
  font-weight: 800;
  background: rgba(255, 240, 242, 0.9);
}

.category-grid {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-auto-rows: 120rpx;
  margin: 24rpx 0 26rpx;
  overflow: hidden;
  border: 2rpx solid rgba(124, 85, 63, 0.18);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: none;
}

.category-chip {
  width: 100%;
  min-width: 0;
  height: 120rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0;
  border: 0;
  border-right: 1rpx solid rgba(124, 85, 63, 0.12);
  border-bottom: 1rpx solid rgba(124, 85, 63, 0.12);
  border-radius: 0;
  color: #76594e;
  background: transparent;
  box-shadow: none;
  overflow: hidden;
}

.category-chip::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  background: transparent;
}

.category-chip:nth-child(3n) {
  border-right: 0;
}

.category-chip:nth-child(n + 4) {
  border-bottom: 0;
}

.chip-icon-wrap {
  position: relative;
  z-index: 1;
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip-image {
  width: 42rpx;
  height: 42rpx;
  display: block;
}

.chip-plus {
  width: 42rpx;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  background: #77b7a8;
}

.chip-label {
  position: relative;
  z-index: 1;
  max-width: 100%;
  overflow: hidden;
  color: inherit;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-chip.active {
  color: #fff;
  background: transparent;
  box-shadow: none;
}

.category-chip.active::before {
  background: linear-gradient(135deg, #e9665d, #de4f77);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.26);
}

.category-chip.active .chip-plus {
  color: #e85b80;
  background: #fff;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin: 12rpx 2rpx 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
}

.recipe-list,
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.swipe-scroll {
  width: 100%;
  border-radius: 8rpx;
  overflow: hidden;
}

.swipe-track {
  width: calc(100% + 152rpx);
  display: flex;
  align-items: stretch;
}

.delete-action {
  width: 152rpx;
  flex: 0 0 152rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 8rpx 8rpx 0;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #e85b80, #d84d5d);
}

.recipe-card,
.recipe-skeleton {
  display: grid;
  grid-template-columns: 178rpx minmax(0, 1fr);
  gap: 20rpx;
  min-height: 202rpx;
  padding: 16rpx;
  animation: floatIn 420ms ease both;
}

.swipe-track .recipe-card {
  width: calc(100% - 152rpx);
  flex: 0 0 calc(100% - 152rpx);
}

.recipe-image-wrap,
.recipe-image,
.skeleton-img {
  width: 178rpx;
  height: 170rpx;
  border-radius: 8rpx;
  background-color: #f3dfd4;
}

.recipe-image-wrap {
  position: relative;
  overflow: hidden;
}

.recipe-image {
  display: block;
}

.favorite-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  z-index: 2;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #d95b6b;
  font-size: 28rpx;
  font-weight: 800;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 18rpx rgba(102, 68, 48, 0.16);
}

.favorite-btn.active {
  color: #fff;
  background: linear-gradient(135deg, #ed725f, #e85b80);
}

.recipe-info,
.skeleton-lines {
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.recipe-topline {
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
  align-items: flex-start;
}

.recipe-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: #32211c;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.28;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-time {
  flex-shrink: 0;
  max-width: 132rpx;
  overflow: hidden;
  padding: 9rpx 12rpx;
  border-radius: 8rpx;
  color: #df6570;
  font-size: 20rpx;
  background: #fff0ee;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-desc {
  display: -webkit-box;
  overflow: hidden;
  color: #796057;
  font-size: 24rpx;
  line-height: 1.48;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.recipe-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  color: #9b8075;
  font-size: 22rpx;
}

.banner-skeleton,
.skeleton-img,
.skeleton-line {
  background: linear-gradient(90deg, #fff0e8, #fffaf7, #fff0e8);
  background-size: 300% 100%;
  animation: shimmer 1.4s ease infinite;
}

.skeleton-line {
  height: 26rpx;
  border-radius: 8rpx;
}

.skeleton-line.strong {
  width: 70%;
  height: 34rpx;
}

.skeleton-line.short {
  width: 46%;
}

.load-more {
  margin-top: 6rpx;
}

.end-tip {
  padding: 18rpx 0 8rpx;
  color: #9a7a70;
  font-size: 23rpx;
  text-align: center;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  padding: 60rpx 36rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 800;
}

.empty-text {
  color: #8b6d63;
  font-size: 25rpx;
  line-height: 1.5;
}

.category-chip:active,
.recipe-card:active,
.admin-entry:active,
.friend-entry:active,
.load-more:active,
.search-btn:active,
.add-mini-btn:active,
.wheel-entry:active,
.clear-search:active {
  transform: scale(0.99);
}

@media (max-width: 340px) {
  .topbar {
    flex-direction: column;
  }

  .top-actions {
    width: 100%;
    max-width: none;
    justify-content: flex-start;
  }

  .recipe-card,
  .recipe-skeleton {
    grid-template-columns: 150rpx minmax(0, 1fr);
    gap: 16rpx;
  }

  .recipe-image-wrap,
  .recipe-image,
  .skeleton-img {
    width: 150rpx;
    height: 150rpx;
  }
}

@keyframes shimmer {
  0% {
    background-position: 100% 0;
  }
  100% {
    background-position: 0 0;
  }
}
