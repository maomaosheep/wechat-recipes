.add-page {
  padding-bottom: 118rpx;
}

.intro {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 12rpx 4rpx 24rpx;
  animation: floatIn 460ms ease both;
}

.eyebrow {
  color: #d56070;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  color: #35231d;
  font-size: 42rpx;
  font-weight: 800;
}

.subtitle {
  color: #80665e;
  font-size: 25rpx;
  line-height: 1.58;
}

.form-card {
  margin-top: 24rpx;
  padding: 24rpx;
  animation: floatIn 460ms ease both;
}

.image-picker {
  width: 100%;
  height: 340rpx;
  overflow: hidden;
  border: 1rpx dashed rgba(218, 107, 119, 0.45);
  border-radius: 8rpx;
  background: #fff4ef;
}

.picked-image {
  width: 100%;
  height: 100%;
}

.picker-empty {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  color: #d86172;
  font-size: 26rpx;
  font-weight: 700;
}

.picker-icon {
  width: 74rpx;
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #fff;
  font-size: 44rpx;
  background: linear-gradient(135deg, #f17a68, #e65a7a);
  box-shadow: 0 14rpx 28rpx rgba(226, 89, 112, 0.2);
}

.field {
  margin-top: 24rpx;
}

.field-label,
.section-title {
  display: block;
  margin-bottom: 12rpx;
  color: #3a2821;
  font-size: 27rpx;
  font-weight: 800;
}

.input,
.textarea {
  width: 100%;
  min-height: 82rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(114, 80, 61, 0.1);
  border-radius: 8rpx;
  color: #3d2b25;
  font-size: 26rpx;
  background: #fffaf7;
}

.textarea {
  height: 150rpx;
  line-height: 1.5;
}

.textarea.small {
  height: 118rpx;
}

.list-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.mini-btn {
  height: 58rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 23rpx;
  font-weight: 700;
  background: #77b7a8;
}

.row-input {
  display: grid;
  grid-template-columns: 1fr 58rpx;
  gap: 12rpx;
  align-items: center;
  margin-top: 14rpx;
}

.step-row {
  align-items: start;
}

.remove-btn {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #d76070;
  font-size: 36rpx;
  background: #fff0ee;
}

.save-btn {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  z-index: 10;
}
